# ==============================================================================
# UNIVERSITY THREAT DETECTION — ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Instructions:
# 1. Copy this file to '.env' in the same directory: cp .env.example .env
# 2. Update the values in '.env' with your local environment settings.
# 3. WARNING: Never commit '.env' containing real secrets to version control!
# ==============================================================================

# --- DATABASE CONFIGURATION ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=threat_detection
POSTGRES_USER=analyst
POSTGRES_PASSWORD=your_password_here

# SQLAlchemy Database Connection URL (Required by backend & pipeline)
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql+psycopg2://analyst:your_password_here@localhost:5432/threat_detection

# --- SECURITY & API CONFIGURATION ---
# Generate a secure secret key using: openssl rand -hex 32
# Required by FastAPI backend for token signing
JWT_SECRET_KEY=your_secure_jwt_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- DATA NORMALIZATION & MASKING ---
# Static salt used for deterministic PII hashing (emails, usernames).
# Keep this consistent across environments to ensure identical masking results.
STATIC_SALT=default_normalization_salt_2026

# --- LOG STORAGE & MONITORING ---
LOKI_URL=http://localhost:3100
# ELASTICSEARCH_URL=http://localhost:9200

# --- GRAFANA CONFIGURATION ---
GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=your_grafana_password

# --- MACHINE LEARNING & RISK ENGINE CONFIGURATION ---
MODEL_CONTAMINATION=0.05
FEATURE_WINDOW_MINUTES=5
RISK_THRESHOLD=0.7
